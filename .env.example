# AI mode (default) uses a Groq vision model to redraw sketches as clean shapes.
# Get a key at https://console.groq.com/keys. The other modes (Trace / Line /
# Edge) are fully local and need no key.
GROQ_API_KEY=your_groq_api_key_here
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Server
PORT=3001
NODE_ENV=development

# CORS origin for the Vite client
CLIENT_ORIGIN=http://localhost:5173
